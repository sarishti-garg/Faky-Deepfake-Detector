# ==========================================
# Project-Specific Ignores
# ==========================================
# Ignore all uploaded files but keep the uploads directory structure
uploads/*
!uploads/.gitkeep

# Ignore large PyTorch model weights/parameters
*.pt
*.pth
*.onnx
*.bin

# ==========================================
# Python Standard Ignores
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# IDEs and Editors
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# OS Files
# ==========================================
.DS_Store
Thumbs.db
